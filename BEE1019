import java.io.IOException;
import java.util.Scanner;

public class Main {
 
    public static void main(String[] args) throws IOException {
 
        Scanner input = new Scanner(System.in);
        
        int n;
        int hora;
        int minutos;
        int segundos;
        int resto;
        
        n = input.nextInt();
        
        hora = n / 3600; 
        resto = n % 3600; 
        minutos = resto / 60;
        segundos = resto % 60;
        
        System.out.println(hora + ":" + minutos + ":" + segundos);
        
 
    }
 
}
